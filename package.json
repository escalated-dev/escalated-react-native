{
  "name": "@escalated-dev/escalated-react-native",
  "version": "0.1.0",
  "description": "React Native UI library for Escalated support ticket systems",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepare": "tsc --noEmit"
  },
  "peerDependencies": {
    "@react-navigation/bottom-tabs": ">=7.0.0",
    "@react-navigation/native": ">=7.0.0",
    "@react-navigation/native-stack": ">=7.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-screens": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@react-navigation/bottom-tabs": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "expo-document-picker": "^55.0.8",
    "expo-secure-store": "^55.0.8",
    "react-native-render-html": "^6.3.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "typescript": "~5.9.2"
  },
  "keywords": [
    "react-native",
    "support",
    "tickets",
    "helpdesk",
    "knowledge-base",
    "escalated"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/escalated-dev/escalated-react-native.git"
